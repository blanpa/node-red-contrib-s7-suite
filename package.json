{
  "name": "node-red-contrib-s7-suite",
  "version": "0.0.4",
  "description": "Node-RED nodes for Siemens S7 PLC communication with dual backend support (nodes7 + node-snap7)",
  "keywords": [
    "node-red",
    "siemens",
    "s7",
    "plc",
    "snap7",
    "nodes7",
    "s7-200",
    "s7-300",
    "s7-400",
    "s7-1200",
    "s7-1500"
  ],
  "license": "MIT",
  "author": "LA",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blanpa/node-red-contrib-s7-suite.git"
  },
  "bugs": {
    "url": "https://github.com/blanpa/node-red-contrib-s7-suite/issues"
  },
  "homepage": "https://github.com/blanpa/node-red-contrib-s7-suite#readme",
  "main": "dist/nodes/index.js",
  "scripts": {
    "build": "tsc && npm run copy-html",
    "copy-html": "copyfiles -u 1 \"src/nodes/**/*.html\" dist/ && copyfiles -u 1 \"src/icons/*\" dist/icons/",
    "test": "jest --coverage",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'test/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "prepublishOnly": "npm run build"
  },
  "node-red": {
    "version": ">=2.0.0",
    "nodes": {
      "s7-config": "dist/nodes/s7-config/s7-config.js",
      "s7-read": "dist/nodes/s7-read/s7-read.js",
      "s7-write": "dist/nodes/s7-write/s7-write.js",
      "s7-trigger": "dist/nodes/s7-trigger/s7-trigger.js",
      "s7-browse": "dist/nodes/s7-browse/s7-browse.js",
      "s7-control": "dist/nodes/s7-control/s7-control.js"
    }
  },
  "dependencies": {
    "nodes7": "^0.3.0"
  },
  "optionalDependencies": {
    "node-snap7": "^1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.19.0",
    "@types/node-red": "^1.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "node-red": "^4.1.7",
    "node-red-node-test-helper": "^0.3.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ]
}
