  {
    "id": "browse-format",
    "type": "function",
    "z": "tab-main",
    "name": "Format Result",
    "func": "const r = msg.payload;\nlet summary = '=== Browse Result ===\\n';\nsummary += `Blocks found: ${r.blocks ? r.blocks.length : 0}\\n`;\nif (r.blocks) {\n    r.blocks.forEach(b => {\n        summary += `  ${b.blockType} ${b.blockNumber}: ${b.sizeData} bytes\\n`;\n    });\n}\nsummary += `Areas found: ${r.areas ? r.areas.length : 0}\\n`;\nif (r.areas) {\n    r.areas.forEach(a => {\n        summary += `  ${a.area}: ${a.size} bytes\\n`;\n    });\n}\nmsg.summary = summary;\nnode.warn(summary);\nreturn msg;",
    "outputs": 1,
    "x": 660,
    "y": 1800,
    "wires": [
      [
        "debug-browse-all"
      ]
    ]
