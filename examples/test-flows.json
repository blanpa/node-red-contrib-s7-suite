  {
    "id": "roundtrip-check",
    "type": "function",
    "z": "tab-main",
    "name": "Verify \u2248 99.9",
    "func": "const written = 99.9;\nconst read = msg.payload;\nconst diff = Math.abs(read - written);\nif (diff < 0.1) {\n    msg.result = 'PASS';\n    msg.detail = `Written: ${written}, Read: ${read}, Diff: ${diff.toFixed(4)}`;\n} else {\n    msg.result = 'FAIL';\n    msg.detail = `Written: ${written}, Read: ${read}, Diff: ${diff.toFixed(4)}`;\n}\nnode.status({fill: msg.result === 'PASS' ? 'green' : 'red', shape: 'dot', text: msg.result});\nreturn msg;",
    "outputs": 1,
    "x": 650,
    "y": 1220,
    "wires": [
      [
        "debug-roundtrip"
      ]
    ]
