    "id": "roundtrip-s7300-check",
    "type": "function",
    "z": "tab-s7-300",
    "name": "Verify Roundtrip",
    "func": "const written = msg._written;\nconst readBack = msg.payload;\nconst match = (written === readBack);\nmsg.result = {\n    status: match ? 'PASS' : 'FAIL',\n    address: msg.topic,\n    written: written,\n    readBack: readBack\n};\nnode.status({\n    fill: match ? 'green' : 'red',\n    shape: 'dot',\n    text: match ? `PASS: ${readBack}` : `FAIL: ${written} != ${readBack}`\n});\nreturn msg;",
