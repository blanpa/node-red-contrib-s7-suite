  {
    "id": "s7300-buffer-hex",
    "type": "function",
    "z": "tab-s7-300",
    "name": "Format Hex",
    "func": "if (Buffer.isBuffer(msg.payload)) {\n    const buf = msg.payload;\n    msg.hex = buf.toString('hex').match(/.{1,2}/g).join(' ');\n    msg.bytes = Array.from(buf);\n    node.status({text: msg.hex});\n}\nreturn msg;",
    "outputs": 1,
    "x": 670,
    "y": 1380,
    "wires": [["debug-s7300-buffer"]]
  },
